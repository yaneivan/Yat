# Yat HTR Annotation Tool - Environment Configuration
# Скопируйте этот файл в .env и настройте под себя

# =============================================================================
# Authentication Mode
# =============================================================================
# Два режима работы:
#
# 1. Открытый доступ (без паролей):
#    - Закомментируйте ADMIN_PASSWORD и USER_PASSWORD
#    - Вход без пароля, все пользователи имеют полный доступ
#
# 2. Ролевой доступ (требуются оба пароля):
#    - Раскомментируйте и установите оба пароля
#    - Требуется вход в систему
#    - Admin: полный доступ (создание/удаление проектов, загрузка изображений)
#    - User: чтение (аннотирование, распознавание текста, экспорт)
#
# ВАЖНО: Нужно установить ОБА пароля или НИ ОДНОГО. Один пароль вызовет ошибку.
# =============================================================================

# Пароль администратора - полный доступ
ADMIN_PASSWORD=your_admin_password_here

# Пароль пользователя - доступ только на чтение
USER_PASSWORD=your_user_password_here

# =============================================================================
# Session Security
# =============================================================================
# Секретный ключ для шифрования сессий
# ВАЖНО: Используйте уникальный ключ в production!
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production

# =============================================================================
# CSRF Protection
# =============================================================================
# Защита от CSRF-атак
#
# Для разработки по HTTP (внешний IP): false
# Для production (HTTPS или localhost): true
#
# CSRF защита требует HTTPS для полной безопасности.
# При работе по HTTP через внешний IP рекомендуется отключить.
# =============================================================================

CSRF_ENABLED=false

# =============================================================================
# AI Model Configuration (optional)
# =============================================================================
# Путь к модели YOLO для детекции текстовых строк
# YOLO_MODEL_PATH=./models/model.pt

# Модель TROCR для распознавания текста (HuggingFace)
# TROCR_MODEL_NAME=raxtemur/trocr-base-ru

# Принудительно использовать CPU вместо GPU
# USE_CPU=false
