# E2E tests configuration
# For local development: copy to .env and adjust if needed
# cp tests/e2e/.env.example tests/e2e/.env

# Автозапуск сервера (true/false)
USE_AUTOMATIC_SERVER=true

# URL сервера (если USE_AUTOMATIC_SERVER=false)
SERVER_URL=http://127.0.0.1:5000

# Учётка для тестов по умолчанию
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Запуск с видимым браузером (true/false, дефолт false = headless)
HEADED=false